generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ArticleStatus {
  draft
  in_review
  published
  archived      // opcional no escopo — deixei pronto, custa zero
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String        // Markdown
  status          ArticleStatus @default(draft)

  // Categoria (opcional) — slug de uma lista FIXA validada na app (lib/categories).
  // String? em vez de enum: mantém a migration aditiva (só ADD COLUMN) e deixa a
  // lista evoluir sem migration. Null = sem categoria (os artigos antigos seguem
  // funcionando). Indexada porque o filtro público do /blog consulta por ela.
  category        String?

  // SEO
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  ogImage         String?

  // Imagem (opcional) — crédito obrigatório se houver imagem
  imageCredit     String?
  imageSourceUrl  String?

  // Opções de capa geradas por IA ainda PENDENTES de confirmação. Guarda as URLs
  // (Vercel Blob) das 4 variações; a marcada vira `ogImage`. Enquanto houver itens
  // aqui, a escolha não foi confirmada (sobrevive a reload). Ao salvar o artigo, a
  // marcada é confirmada, as demais são apagadas do Blob e este campo esvazia.
  imageOptions    String[]      @default([])

  // Rastreabilidade de IA (exigência de disclaimer do teste)
  aiAssisted      Boolean       @default(false)
  aiModel         String?

  // Origem da criação. Null = fluxo humano/manual (todo o app hoje). "cron-daily"
  // = publicação diária automática (o cron da madrugada). String? nullable pelo
  // mesmo motivo de `category`: migration aditiva (só ADD COLUMN), sem tocar nos
  // artigos existentes, e o vocabulário pode crescer sem migration. Usado pela
  // idempotência do cron (não recriar o artigo do dia) e disponível pra um badge
  // "gerado automaticamente" no futuro.
  createdVia      String?

  publishedAt     DateTime?
  // A partir de quando um artigo publicado deve aparecer no blog. Null =
  // aparece assim que publicado (comportamento padrão). Data futura = fica
  // published, mas invisível ao público até a hora (agendamento sem cron —
  // o filtro é aplicado na query pública). Gravado sempre em UTC.
  publishAt       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  sources         Source[]

  @@index([status])   // painel admin filtra por status o tempo todo
  @@index([category]) // filtro público do /blog consulta por categoria
}

model Source {
  id         String   @id @default(cuid())
  title      String
  url        String
  accessedAt DateTime @default(now())

  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId  String

  @@index([articleId])
}