DATABASE_URL=
JWT_SECRET=
ADMIN_EMAIL=
ADMIN_PASSWORD=
OPENROUTER_API_KEY=
# Modelos abaixo são os DEFAULTS: usados quando o seletor de modelo na geração
# não envia uma escolha (ou envia uma inválida). O seletor lista modelos curados
# da OpenRouter em runtime; estes env pré-selecionam a opção padrão de cada fluxo.
OPENROUTER_MODEL=google/gemini-3.1-flash-lite
WEB_SEARCH_MODEL=perplexity/sonar
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-lite-image
OPENROUTER_IDEAS_MODEL=google/gemini-3.1-flash-lite
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_SITE_URL=
# Chave do Firecrawl (fc-...), motor de busca PADRÃO do generate-auto: o Firecrawl
# busca as fontes na web e o modelo de texto escreve. Sem esta chave (ou se o
# Firecrawl falhar/estourar crédito), a busca cai automaticamente no Sonar.
FIRECRAWL_API_KEY=